{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/lock-event-days",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/run-matching-locked",
      "schedule": "1 6 * * *"
    },
    {
      "path": "/api/cron/send-matching-proposal",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/send-day-before-final",
      "schedule": "0 8 * * *"
    }
  ]
}
