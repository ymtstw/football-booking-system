# コピーして .env.local を作成し、値を入れる（.env.local はコミットしない）
# 変数名は本番・Staging 共通。接続先を変えるときは値だけ差し替える。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Staging 用 Supabase（別プロジェクト）---
# 手順は docs/setup-staging-supabase.md。Vercel の Preview 用 Environment Variables に、
# 上記と同じキー名で Staging プロジェクトの URL / anon / service_role を登録する。

# --- Resend（予約完了メール）---
# https://resend.com/api-keys 。未設定のときはメールを送らず notifications は pending のまま。
# テストキー＋未検証ドメインでは「宛先は Resend 登録メールのみ」に制限されがち（予約の代表メール宛は失敗し得る）。docs/setup-resend-domain.md 参照。
# 独自ドメイン・DNS 検証・Vercel 反映の手順: docs/setup-resend-domain.md
RESEND_API_KEY=
# 例: 交流試合 <onboarding@resend.dev> または検証済みドメインの From
RESEND_FROM=

# --- 運営向け（バッチ失敗ダイジェスト・合宿/お問い合わせ通知のフォールバック宛先）---
# 前日最終・2日前マッチング案内・最少催行中止メールなどで失敗があったとき 1 通送る。
# また CAMP_INQUIRY_NOTIFY_EMAIL / TOURNAMENT_INQUIRY_NOTIFY_EMAIL が未設定のとき、
# 合宿・お問い合わせの新着通知もこの宛先に送る（どれも未設定ならメールは送らない）。
OPS_NOTIFY_EMAIL=ymtstwdev@gmail.com

# --- お問い合わせ（大会・サイト一般・運営通知）---
# 未設定時は OPS_NOTIFY_EMAIL にフォールバック。どちらも無ければ DB のみ。
# TOURNAMENT_INQUIRY_NOTIFY_EMAIL=ops@example.com

# --- 合宿相談フォーム（運営通知）---
# 未設定時は OPS_NOTIFY_EMAIL にフォールバック。どちらも無ければ DB のみ。
# CAMP_INQUIRY_NOTIFY_EMAIL=ops@example.com
# メール内の予約確認ページリンク用（末尾スラッシュなし推奨）。例: https://xxxx.vercel.app
NEXT_PUBLIC_SITE_URL=

# --- 一般向けフッター（電話・受付時間）---
# 未設定時は reserve フッターにフォールバック文言を表示します。
# NEXT_PUBLIC_CONTACT_PHONE=04-1234-5678
# NEXT_PUBLIC_CONTACT_HOURS_JA=平日 9:00〜17:00

# --- Vercel Cron（開催日の締切後ロック）---
# ランダム 16 文字以上推奨。Vercel に登録すると Cron 実行時に Authorization: Bearer が付く。
# ローカルで試すときのみ .env.local に値を入れる。
CRON_SECRET=

# --- ローカルで Cron 4本を叩く（npm run cron:local-day-before）---
# 省略時は http://localhost:3000 。`next dev -p 3001` なら例のようにする。
# LOCAL_CRON_BASE_URL=http://localhost:3001
