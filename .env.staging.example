# staging スモーク（npm run test:staging）用。
# vitest.staging.config.ts が .env.staging.example のあと .env.staging を読み込む。
# 秘密（Cookie 等）は .env.staging にのみ書く（.env.staging は gitignore）。

STAGING_BASE_URL=https://stg-rsv-soccer.greenplanet-project.com

# 任意: MVP-DASH-* を Vitest で通すとき。
# ブラウザで Staging に管理者ログイン後、DevTools → Application → Cookies から
# Cookie ヘッダー用の文字列をコピーして .env.staging の STAGING_ADMIN_COOKIE に設定する。
# 本ファイルには実値を入れない（リポジトリに載せない）。
STAGING_ADMIN_COOKIE=
